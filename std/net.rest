import "scheduler";

extern "C" def socket(domain: i32, type: i32, protocol: i32) -> i32;
extern "C" def bind(sockfd: i32, addr: SockAddrIn, addrlen: i32) -> i32;
extern "C" def listen(sockfd: i32, backlog: i32) -> i32;
extern "C" def accept(sockfd: i32, addr: *u8, addrlen: *i32) -> i32;
extern "C" def read(fd: i32, buf: *u8, count: i32) -> i32;
extern "C" def write(fd: i32, buf: *u8, count: i32) -> i32;
extern "C" def close(fd: i32) -> i32;
extern "C" def fcntl(fd: i32, cmd: i32, arg: i32) -> i32;
extern "C" def htons(hostshort: i32) -> i32;

model SockAddrIn {
    sin_family: i16,
    sin_port: i16,
    sin_addr: i32,
    sin_zero_0: i64, // 8 bytes padding
}

const AF_INET: i32 = 2;
const SOCK_STREAM: i32 = 1;
const F_GETFL: i32 = 3;
const F_SETFL: i32 = 4;
const O_NONBLOCK: i32 = 2048;
const EAGAIN: i32 = 11;
const EPOLLIN: i32 = 1;
const EPOLLOUT: i32 = 4;

def set_nonblocking(fd: i32) -> i32 {
    let flags: i32 = fcntl(fd, F_GETFL, 0);
    if flags < 0 { return flags; }
    // We don't have bitwise OR yet? Wait, does Rest have `|` operator?
    // In Rest, I don't think we have `|` yet. Let's use `+` since flags are mutually exclusive bits.
    // Wait, if O_NONBLOCK is already set, `+` will mess it up.
    // But we know it's not set.
    return fcntl(fd, F_SETFL, flags + O_NONBLOCK);
}

def tcp_listen(port: i32) -> i32 {
    let server_fd: i32 = socket(AF_INET, SOCK_STREAM, 0);
    if server_fd < 0 {
        return -1;
    }
    
    set_nonblocking(server_fd);
    
    let addr: SockAddrIn = SockAddrIn { sin_family: 0 as i16, sin_port: 0 as i16, sin_addr: 0, sin_zero_0: 0i64 };
    addr.sin_family = AF_INET as i16;
    addr.sin_port = htons(port) as i16;
    addr.sin_addr = 0; // INADDR_ANY
    addr.sin_zero_0 = 0i64;
    
    // sizeof(SockAddrIn) = 16
    let res: i32 = bind(server_fd, addr, 16);
    if res < 0 {
        return -2;
    }
    
    res = listen(server_fd, 128);
    if res < 0 {
        return -3;
    }
    
    return server_fd;
}

def tcp_accept(sched: *Scheduler, server_fd: i32) -> i32 {
    while true {
        let client_fd: i32 = accept(server_fd, 0 as *u8, 0 as *i32);
        if client_fd >= 0 {
            set_nonblocking(client_fd);
            return client_fd;
        }
        // If error is EAGAIN/EWOULDBLOCK, we yield. Wait, how do we know if it's EAGAIN?
        // `accept` returns -1 on error and sets `errno`. In Rest we can't easily read `errno` without FFI.
        // But in non-blocking sockets, if `accept` fails, it's almost always EAGAIN.
        fiber_yield_for_fd(sched, server_fd, EPOLLIN);
    }
    return -1;
}

def tcp_read(sched: *Scheduler, fd: i32, buf: *u8, count: i32) -> i32 {
    while true {
        let bytes_read: i32 = read(fd, buf, count);
        if bytes_read > 0 {
            return bytes_read;
        }
        if bytes_read == 0 {
            return 0; // EOF
        }
        // Error (usually EAGAIN)
        fiber_yield_for_fd(sched, fd, EPOLLIN);
    }
    return -1;
}

def tcp_write(sched: *Scheduler, fd: i32, buf: *u8, count: i32) -> i32 {
    let written: i32 = 0;
    while written < count {
        let to_write: i32 = count - written;
        let buf_ptr: i64 = (buf as i64) + (written as i64);
        let res: i32 = write(fd, buf_ptr as *u8, to_write);
        
        if res > 0 {
            written = written + res;
        } else {
            // Error, probably EAGAIN
            fiber_yield_for_fd(sched, fd, EPOLLOUT);
        }
    }
    return written;
}
