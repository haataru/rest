// Zero-copy HTTP Parser

// Constants for HTTP Methods
// UNKNOWN = 0
// GET     = 1
// POST    = 2
// PUT     = 3
// DELETE  = 4
// HEAD    = 5
// OPTIONS = 6
// PATCH   = 7
// TRACE   = 8

model HttpHeader {
    name: *u8,
    name_len: i32,
    value: *u8,
    value_len: i32,
}

model HttpRequest {
    method: i32,
    path: *u8,
    path_len: i32,
    version: i32,
    
    headers: *HttpHeader,
    max_headers: i32,
    num_headers: i32,
    
    body: *u8,
    body_len: i32,
}

def http_strncmp(s1: *u8, s2: *u8, n: i32) -> i32 {
    let i: i32 = 0;
    while (i < n) {
        let p1: *u8 = ((s1 as i64) + (i as i64)) as *u8;
        let p2: *u8 = ((s2 as i64) + (i as i64)) as *u8;
        let c1: u8 = *p1;
        let c2: u8 = *p2;
        let diff: i32 = (c1 as i32) - (c2 as i32);
        if diff != 0 {
            return diff;
        }
        if (c1 as i32) == 0 {
            return 0;
        }
        i = i + 1;
    }
    return 0;
}

// Find a character in buffer. Returns index or -1
def find_char(buf: *u8, len: i32, c: u8) -> i32 {
    let i: i32 = 0;
    while (i < len) {
        let p: *u8 = ((buf as i64) + (i as i64)) as *u8;
        let curr: u8 = *p;
        if (curr as i32) == (c as i32) {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

def parse_method(method_str: *u8, len: i32) -> i32 {
    if len == 3 {
        if http_strncmp(method_str, "GET" as *u8, 3) == 0 { return 1; }
        if http_strncmp(method_str, "PUT" as *u8, 3) == 0 { return 3; }
    } else {
        if len == 4 {
            if http_strncmp(method_str, "POST" as *u8, 4) == 0 { return 2; }
            if http_strncmp(method_str, "HEAD" as *u8, 4) == 0 { return 5; }
        } else {
            if len == 5 {
                if http_strncmp(method_str, "PATCH" as *u8, 5) == 0 { return 7; }
                if http_strncmp(method_str, "TRACE" as *u8, 5) == 0 { return 8; }
            } else {
                if len == 6 {
                    if http_strncmp(method_str, "DELETE" as *u8, 6) == 0 { return 4; }
                } else {
                    if len == 7 {
                        if http_strncmp(method_str, "OPTIONS" as *u8, 7) == 0 { return 6; }
                    }
                }
            }
        }
    }
    return 0;
}

// Parse HTTP request
// Returns bytes parsed (>0), 0 if incomplete, -1 on error.
def parse_http_request(buf: *u8, len: i32, req: *HttpRequest) -> i32 {
    // 1. Parse Request-Line
    // Format: METHOD PATH HTTP/1.1\r\n
    
    let space1: i32 = find_char(buf, len, 32 as u8); // 32 is ' '
    if (space1 == -1) {
        return 0; // incomplete
    }
    
    (*req).method = parse_method(buf, space1);
    
    let buf_after_method: *u8 = ((buf as i64) + (space1 as i64) + 1i64) as *u8;
    let len_after_method: i32 = len - space1 - 1;
    
    let space2: i32 = find_char(buf_after_method, len_after_method, 32 as u8);
    if (space2 == -1) {
        return 0; // incomplete
    }
    
    (*req).path = buf_after_method;
    (*req).path_len = space2;
    
    let buf_after_path: *u8 = ((buf_after_method as i64) + (space2 as i64) + 1i64) as *u8;
    let len_after_path: i32 = len_after_method - space2 - 1;
    
    let r_char: i32 = find_char(buf_after_path, len_after_path, 13 as u8); // 13 is '\r'
    if (r_char == -1) {
        return 0; // incomplete
    }
    
    // check if \n follows
    let r_next: i32 = r_char + 1;
    if (r_next == len_after_path) {
        return 0; // incomplete
    }
    let n_char_ptr: *u8 = ((buf_after_path as i64) + (r_char as i64) + 1i64) as *u8;
    let n_char: u8 = *n_char_ptr;
    if (n_char as i32) != 10 { // 10 is '\n'
        return -1; // error
    }
    
    // We assume HTTP/1.1 for now.
    (*req).version = 11; 
    
    // Advance to headers
    let curr_buf: *u8 = ((buf_after_path as i64) + (r_char as i64) + 2i64) as *u8;
    let curr_len: i32 = len_after_path - r_char - 2;
    let parsed_bytes: i32 = (curr_buf as i64 - buf as i64) as i32;
    
    (*req).num_headers = 0;
    
    let done_headers: i32 = 0;
    while (done_headers == 0) {
        if (curr_len < 2) {
            return 0; // incomplete
        }
        
        // Check for empty line \r\n (end of headers)
        let c0: u8 = *curr_buf;
        let c1_ptr: *u8 = ((curr_buf as i64) + 1i64) as *u8;
        let c1: u8 = *c1_ptr;
        if (c0 as i32) == 13 {
            if (c1 as i32) == 10 {
                // End of headers
                curr_buf = ((curr_buf as i64) + 2i64) as *u8;
                curr_len = curr_len - 2;
                parsed_bytes = parsed_bytes + 2;
                done_headers = 1;
            } else {
                return -1; // error
            }
        } else {
            // Parse header: "Name: Value\r\n"
            let colon: i32 = find_char(curr_buf, curr_len, 58 as u8); // 58 is ':'
            if (colon == -1) {
                return 0; // incomplete
            }
            
            let name_ptr: *u8 = curr_buf;
            let name_len: i32 = colon;
            
            curr_buf = ((curr_buf as i64) + (colon as i64) + 1i64) as *u8;
            curr_len = curr_len - colon - 1;
            parsed_bytes = parsed_bytes + colon + 1;
            
            // Skip spaces
            let space_skip: i32 = 0;
            while (space_skip == 0) {
                if (curr_len == 0) {
                    return 0; // incomplete
                }
                let sc: u8 = *curr_buf;
                if (sc as i32) == 32 {
                    curr_buf = ((curr_buf as i64) + 1i64) as *u8;
                    curr_len = curr_len - 1;
                    parsed_bytes = parsed_bytes + 1;
                } else {
                    space_skip = 1;
                }
            }
            
            let r_pos: i32 = find_char(curr_buf, curr_len, 13 as u8); // '\r'
            if (r_pos == -1) {
                return 0; // incomplete
            }
            
            let val_ptr: *u8 = curr_buf;
            let val_len: i32 = r_pos;
            
            let r_pos_next: i32 = r_pos + 1;
            if (r_pos_next == curr_len) {
                return 0;
            }
            let n_ptr: *u8 = ((curr_buf as i64) + (r_pos as i64) + 1i64) as *u8;
            let nc: u8 = *n_ptr;
            if (nc as i32) != 10 {
                return -1;
            }
            
            curr_buf = ((curr_buf as i64) + (r_pos as i64) + 2i64) as *u8;
            curr_len = curr_len - r_pos - 2;
            parsed_bytes = parsed_bytes + r_pos + 2;
            
            // Save header if there is space
            if ((*req).num_headers < (*req).max_headers) {
                let h_idx: i32 = (*req).num_headers;
                let offset: i64 = (h_idx as i64) * 24i64; // sizeof HttpHeader is 24 ? Let's verify: *u8 (8), i32 (4), *u8 (8), i32 (4) -> 24! Wait, struct padding makes it 32? No! 8+4 = 12. 12 pad to 16? 16+8=24. 24+4=28. pad to 32?
                // Let's use 32 just in case LLVM pads to multiple of 8.
                let hdr: *HttpHeader = (((*req).headers as i64) + ((h_idx as i64) * 32i64)) as *HttpHeader;
                (*hdr).name = name_ptr;
                (*hdr).name_len = name_len;
                (*hdr).value = val_ptr;
                (*hdr).value_len = val_len;
                (*req).num_headers = h_idx + 1;
            }
        }
    }
    
    // Parse Body
    // Simple for now: everything left is body
    (*req).body = curr_buf;
    (*req).body_len = curr_len;
    
    return parsed_bytes;
}
